PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox
ENCRYPTION_KEY=base64_encoded_32_byte_key_here
COLLECTR_SHARE_URL=https://your-collectr-share-link-here
PORT=8123
# Bind host. Keep 127.0.0.1 (loopback). Non-loopback values expose the API
# to the network without TLS/auth — the server logs a prominent warning.
HOST=127.0.0.1
# Optional: override the SQLite database file path.
# Default: server/data/networth.db. The packaged macOS app sets this to the
# Electron user-data directory automatically.
# DB_PATH=/absolute/path/to/networth.db
