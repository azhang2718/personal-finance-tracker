{
  "name": "networth-tracker",
  "productName": "Net Worth Tracker",
  "version": "1.0.0",
  "description": "Local-first personal net worth tracker (Electron desktop app)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/copy-chartjs.js",
    "dist": "electron-builder --mac",
    "audit": "npm audit"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.local.networth-tracker",
    "productName": "Net Worth Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "windows/**",
      "shared/**",
      "lib/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../server",
        "to": "server",
        "filter": [
          "**/*",
          "!data/**",
          "!.env",
          "!*.db"
        ]
      }
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "category": "public.app-category.finance"
    }
  }
}
