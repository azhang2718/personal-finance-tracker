{
  "name": "networth-tracker",
  "productName": "Net Worth Tracker",
  "version": "1.0.0",
  "description": "Local-first personal net worth tracker (Electron desktop app)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/copy-chartjs.js",
    "dist": "electron-builder --mac",
    "audit": "npm audit"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.local.networth-tracker",
    "productName": "Net Worth Tracker",
    "directories": {
      "output": "dist"
    },
    "beforePack": "./scripts/rebuild-server-native.js",
    "files": [
      "main.js",
      "preload.js",
      "windows/**",
      "shared/**",
      "lib/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build-server",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!data/**",
          "!.env",
          "!*.db",
          "!**/*.md"
        ]
      },
      {
        "from": "build-server/node_modules",
        "to": "server/node_modules"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance"
    }
  }
}
